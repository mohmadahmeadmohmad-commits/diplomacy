{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the real estate marketplace",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "role": { "type": "string", "enum": ["admin", "agent", "owner", "customer"], "description": "User's role in the platform" },
        "phone": { "type": "string", "description": "User's phone number" },
        "favorites": { "type": "array", "items": { "type": "string" }, "description": "List of favorite property IDs" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    },
    "Property": {
      "title": "Property",
      "description": "A real estate property listing",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique property ID" },
        "ownerId": { "type": "string", "description": "UID of the user who created the listing" },
        "title": { "type": "string", "description": "Title of the listing" },
        "description": { "type": "string", "description": "Detailed description" },
        "category": { "type": "string", "enum": ["apartment", "villa", "land", "commercial"], "description": "Type of property" },
        "listingType": { "type": "string", "enum": ["sale", "rent"], "description": "Sale or Rent" },
        "price": { "type": "number", "description": "Price in local currency" },
        "area": { "type": "number", "description": "Area in square meters" },
        "location": {
          "type": "object",
          "properties": {
            "governorate": { "type": "string" },
            "city": { "type": "string" },
            "neighborhood": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          },
          "required": ["governorate", "city"]
        },
        "images": { "type": "array", "items": { "type": "string" }, "description": "Array of image URLs" },
        "status": { "type": "string", "enum": ["pending", "published", "rejected"], "description": "Approval status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Listing creation timestamp" }
      },
      "required": ["ownerId", "title", "category", "listingType", "price", "area", "location", "status", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A user review and comment on a property",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "propertyId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["propertyId", "userId", "userName", "text", "rating", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles and roles"
    },
    "properties/{propertyId}": {
      "schema": "Property",
      "description": "Stores all property listings"
    },
    "properties/{propertyId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Stores comments and ratings for a specific property"
    }
  }
}
